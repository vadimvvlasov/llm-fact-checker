# === REQUIRED — fill in both, both free ===

# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# === Everything below already works — leave as-is unless you want to change it ===

POSTGRES_USER=factchecker
POSTGRES_PASSWORD=factchecker
POSTGRES_DB=factchecker
# Docker (Option A) overrides this to `postgres` automatically
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Airflow UI login, http://localhost:8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=airflow

# alternatives: groq, ollama (src/config.py)
LLM_PROVIDER=openrouter
# optional override of the provider's default model — leave empty to use it
LLM_MODEL=

# Only needed if you switch LLM_PROVIDER above:
# https://console.groq.com/keys
# GROQ_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1
