# === REQUIRED — fill in both, both free ===

FRED_API_KEY=          # https://fred.stlouisfed.org/docs/api/api_key.html
OPENROUTER_API_KEY=    # https://openrouter.ai/settings/keys

# === Everything below already works — leave as-is unless you want to change it ===

POSTGRES_USER=factchecker
POSTGRES_PASSWORD=factchecker
POSTGRES_DB=factchecker
POSTGRES_HOST=localhost  # Docker (Option A) overrides this to `postgres` automatically
POSTGRES_PORT=5432

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

AIRFLOW_ADMIN_USER=admin      # Airflow UI login, http://localhost:8080
AIRFLOW_ADMIN_PASSWORD=airflow

LLM_PROVIDER=openrouter  # alternatives: groq, ollama (src/config.py)
LLM_MODEL=               # optional override of the provider's default model

# Only needed if you switch LLM_PROVIDER above:
# GROQ_API_KEY=           # https://console.groq.com/keys
# OLLAMA_BASE_URL=http://localhost:11434/v1
