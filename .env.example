POSTGRES_USER=factchecker
POSTGRES_PASSWORD=factchecker
POSTGRES_DB=factchecker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Free API key: Register at fredaccount.stlouisfed.org
# Limits: 120 requests/min, 100,000 requests/day   
FRED_API_KEY=

# needed from Phase 2 (claim extraction / verification LLM calls)
# LLM_PROVIDER selects one of src/config.py's LLM_PROVIDERS: openrouter (default), groq, ollama
LLM_PROVIDER=openrouter
# LLM_MODEL overrides the provider's default_model (see src/config.py) if set
LLM_MODEL=
# openrouter: free key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# groq: free key at https://console.groq.com/keys
GROQ_API_KEY=
# ollama (local, no key needed): OLLAMA_BASE_URL=http://localhost:11434/v1

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Airflow UI (http://localhost:8080) admin login — used by docker-compose.yml's
# airflow service (_AIRFLOW_WWW_USER_* env vars). Change the password before
# exposing this port beyond localhost.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=airflow
