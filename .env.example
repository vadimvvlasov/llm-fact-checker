POSTGRES_USER=factchecker
POSTGRES_PASSWORD=factchecker
POSTGRES_DB=factchecker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Free API key: Register at fredaccount.stlouisfed.org
# Limits: 120 requests/min, 100,000 requests/day   
FRED_API_KEY=

# needed from Phase 2 (claim extraction / verification LLM calls)
# LLM_PROVIDER=openrouter (default, needs OPENROUTER_API_KEY) or ollama (local, no key needed)
LLM_PROVIDER=openrouter
# free key: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
LLM_MODEL=tencent/hy3:free
# for LLM_PROVIDER=ollama: OLLAMA_BASE_URL=http://localhost:11434/v1, LLM_MODEL=ornith:latest

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
