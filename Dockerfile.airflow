FROM apache/airflow:2.10.5-python3.11

COPY requirements-airflow.txt /tmp/requirements-airflow.txt
RUN pip install --no-cache-dir -r /tmp/requirements-airflow.txt

# src/ and ingest/ are bind-mounted over these paths in docker-compose.yml for
# local dev (edits apply without a rebuild); COPY here only keeps the image
# runnable standalone (e.g. `docker build` + `docker run` without compose).
COPY --chown=airflow:root src ${AIRFLOW_HOME}/src
COPY --chown=airflow:root ingest ${AIRFLOW_HOME}/ingest
